# Neon Postgres — auto-injected by Vercel when the DB integration is connected.
# For local dev: copy from the Neon dashboard → Connection details.
POSTGRES_URL=

# Vercel Blob — auto-injected by Vercel when a Blob store is connected.
# For local dev: copy from the Vercel dashboard → Storage → your Blob store.
BLOB_READ_WRITE_TOKEN=

# Content API secret — set this manually in the Vercel dashboard (Settings → Environment Variables).
# Use any strong random string. The content pipeline sends this as: X-Content-Api-Key: <value>
CONTENT_API_KEY=
